{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataPad++",
  "version": "0.1.42",
  "identifier": "com.datapadplusplus.desktop",
  "build": {
    "beforeDevCommand": "npm run oracle:sidecar:ensure && npm run dev:ensure",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run oracle:sidecar:prepare && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DataPad++",
        "width": 1600,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/datapadplusplus-oracle-runtime"
    ],
    "resources": [
      "resources/licenses/Oracle.ManagedDataAccess.Core-LICENSE.txt"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
