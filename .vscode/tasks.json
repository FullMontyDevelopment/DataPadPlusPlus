{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "datapadplusplus:dev:preflight",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev:preflight"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:oracle:ensure",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "oracle:sidecar:ensure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:rust:build",
      "type": "shell",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path",
        "${workspaceFolder}/apps/desktop/src-tauri/Cargo.toml",
        "--bin",
        "datapadplusplus-desktop"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:up:core",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:up"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:up:profile",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:up:profile",
        "--",
        "${input:datapadplusplusFixtureProfile}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:up:all",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:up:all"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:seed",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:seed"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:seed:all",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:seed:all"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:down",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "fixtures:down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:ready:core",
      "dependsOn": [
        "datapadplusplus:fixtures:up:core",
        "datapadplusplus:fixtures:seed"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:ready:profile",
      "dependsOn": [
        "datapadplusplus:fixtures:up:profile",
        "datapadplusplus:fixtures:seed"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:fixtures:ready:all",
      "dependsOn": [
        "datapadplusplus:fixtures:up:all",
        "datapadplusplus:fixtures:seed:all"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:dev",
      "type": "shell",
      "command": "node",
      "args": [
        ".vscode/ensure-ui-dev.mjs"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:lldb:dev",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:ui:dev"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:services",
      "dependsOn": [
        "datapadplusplus:rust:build",
        "datapadplusplus:ui:dev"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:dev:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:core:services",
      "dependsOn": [
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:core"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:profile:services",
      "dependsOn": [
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:profile"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:all:services",
      "dependsOn": [
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:all"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:core:services",
      "dependsOn": [
        "datapadplusplus:rust:build",
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:core"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:profile:services",
      "dependsOn": [
        "datapadplusplus:rust:build",
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:profile"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:all:services",
      "dependsOn": [
        "datapadplusplus:rust:build",
        "datapadplusplus:ui:dev",
        "datapadplusplus:fixtures:ready:all"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:core",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:ui:fixtures:core:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:profile",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:ui:fixtures:profile:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:ui:fixtures:all",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:ui:fixtures:all:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:core",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:dev:fixtures:core:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:profile",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:dev:fixtures:profile:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "datapadplusplus:dev:fixtures:all",
      "dependsOn": [
        "datapadplusplus:dev:preflight",
        "datapadplusplus:oracle:ensure",
        "datapadplusplus:dev:fixtures:all:services"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "datapadplusplusFixtureProfile",
      "type": "pickString",
      "description": "Fixture profile to start before debugging",
      "options": [
        "cache",
        "sqlplus",
        "analytics",
        "search",
        "graph",
        "widecolumn",
        "oracle",
        "cloud-contract"
      ],
      "default": "sqlplus"
    }
  ]
}
